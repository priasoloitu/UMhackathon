# ─── JadualIQ Environment Variables ─────────────────────────────────────────
# Copy this file to `.env` and fill in your own credentials.
# Never commit the actual `.env` file to version control.

# ─── Z.AI (GLM-4-Flash) — Required ──────────────────────────────────────────
ZAI_API_KEY=your_zai_api_key_here
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZAI_MODEL=glm-4-flash

# ─── OpenWeatherMap — Optional (falls back to simulated data) ─────────────────
OWM_API_KEY=your_owm_api_key_here
DEFAULT_LOCATION=Kuala Lumpur

# ─── Google Maps — Optional (falls back to simulated data) ───────────────────
GOOGLE_MAPS_KEY=your_google_maps_key_here

# ─── Flask ────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_long_random_string
FLASK_DEBUG=false
